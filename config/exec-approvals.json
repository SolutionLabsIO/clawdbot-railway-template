{
  "version": 1,
  "defaults": {
    "security": "allowlist",
    "ask": "never",
    "askFallback": "allow",
    "autoAllowSkills": true
  },
  "agents": {
    "clawdio": {
      "security": "allowlist",
      "ask": "never",
      "askFallback": "allow",
      "autoAllowSkills": true,
      "allowlist": [
        { "pattern": "/usr/bin/curl" },
        { "pattern": "/usr/local/bin/curl" },
        { "pattern": "/usr/bin/python3" },
        { "pattern": "/usr/local/bin/python3" },
        { "pattern": "/bin/bash" },
        { "pattern": "/usr/bin/bash" },
        { "pattern": "/usr/bin/node" },
        { "pattern": "/usr/local/bin/node" },
        { "pattern": "/usr/bin/git" },
        { "pattern": "/usr/local/bin/git" },
        { "pattern": "/bin/ls" },
        { "pattern": "/usr/bin/ls" },
        { "pattern": "/bin/cat" },
        { "pattern": "/usr/bin/cat" },
        { "pattern": "/bin/grep" },
        { "pattern": "/usr/bin/grep" },
        { "pattern": "/usr/bin/find" },
        { "pattern": "/usr/bin/head" },
        { "pattern": "/usr/bin/tail" },
        { "pattern": "/usr/bin/wc" },
        { "pattern": "/usr/bin/jq" },
        { "pattern": "/usr/local/bin/jq" },
        { "pattern": "/bin/date" },
        { "pattern": "/usr/bin/date" },
        { "pattern": "/bin/echo" },
        { "pattern": "/usr/bin/echo" },
        { "pattern": "/bin/mkdir" },
        { "pattern": "/usr/bin/mkdir" },
        { "pattern": "/bin/cp" },
        { "pattern": "/bin/mv" },
        { "pattern": "/usr/bin/touch" },
        { "pattern": "/bin/rm" },
        { "pattern": "/usr/bin/sed" },
        { "pattern": "/bin/sed" },
        { "pattern": "/usr/bin/awk" },
        { "pattern": "/usr/bin/sort" },
        { "pattern": "/usr/bin/uniq" },
        { "pattern": "/usr/bin/tee" },
        { "pattern": "/usr/bin/wget" },
        { "pattern": "/usr/local/bin/wget" }
      ]
    },
    "kimi": {
      "security": "allowlist",
      "ask": "never",
      "askFallback": "allow",
      "autoAllowSkills": true,
      "allowlist": [
        { "pattern": "/usr/bin/curl" },
        { "pattern": "/usr/local/bin/curl" },
        { "pattern": "/usr/bin/python3" },
        { "pattern": "/usr/local/bin/python3" },
        { "pattern": "/bin/bash" },
        { "pattern": "/usr/bin/bash" },
        { "pattern": "/usr/bin/node" },
        { "pattern": "/usr/local/bin/node" },
        { "pattern": "/usr/bin/git" },
        { "pattern": "/usr/local/bin/git" },
        { "pattern": "/bin/ls" },
        { "pattern": "/usr/bin/ls" },
        { "pattern": "/bin/cat" },
        { "pattern": "/usr/bin/cat" },
        { "pattern": "/bin/grep" },
        { "pattern": "/usr/bin/grep" },
        { "pattern": "/usr/bin/find" },
        { "pattern": "/usr/bin/head" },
        { "pattern": "/usr/bin/tail" },
        { "pattern": "/usr/bin/wc" },
        { "pattern": "/usr/bin/jq" },
        { "pattern": "/usr/local/bin/jq" },
        { "pattern": "/bin/date" },
        { "pattern": "/usr/bin/date" },
        { "pattern": "/bin/echo" },
        { "pattern": "/usr/bin/echo" },
        { "pattern": "/bin/mkdir" },
        { "pattern": "/usr/bin/mkdir" }
      ]
    }
  }
}
